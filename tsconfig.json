{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/next-app/*"],
      "@shell/*": ["./src/next-app/*"],
      "@user/previews": ["./src/next-app/fallback/previews.ts"],
      "@user/homepage": ["./src/next-app/fallback/homepage.tsx"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/next-app/next-env.d.ts",
    "src/next-app/.next/types/**/*.ts",
    "playwright.config.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
